# Supabase (required for shifts, HITL, snapshots, catchup, profile, notifications)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Notion (required for ecosystem, tasks, inbox, workspaces)
NOTION_TOKEN_OPENCLAW_2=your-notion-integration-token
# Optional: override DB IDs
# NOTION_TASKS_DB= NOTION_INBOX_DB= NOTION_WORKSPACES_DB= NOTION_AGENT_REGISTRY_DB= NOTION_HEARTBEAT_DB= NOTION_AREAS_DB=

# Gateway (for chat fallback on Fly, heartbeat trigger)
OPENCLAW_GATEWAY_URL=http://localhost:18891
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOKS_TOKEN=  # Same as gateway hooks.token for /hooks/agent, /hooks/wake

# Google OAuth (for Calendar, Gmail, Drive, Contacts, Tasks)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram (for webhook management in Node Operations)
TELEGRAM_BOT_TOKEN=
